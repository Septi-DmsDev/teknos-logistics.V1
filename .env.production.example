# Copy these keys to Coolify Environment Variables for teknos-logistics production.
# Never commit real values. Keep courier credentials server-only in this service.

NODE_ENV="production"
NIXPACKS_NODE_VERSION="24"
PORT="3000"
APP_URL="https://<teknos-logistics-domain>"
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public"

# Admin UI auth.
# Use static-token for first private rollout. Move to supabase after operator auth is ready.
ADMIN_AUTH_PROVIDER="static-token"
ADMIN_JWT_SECRET="<generate-strong-random-secret>"

# Required only when ADMIN_AUTH_PROVIDER="supabase".
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_JWT_SECRET=""

# Script/bootstrap only. Do not keep this in runtime unless a production script needs it.
SUPABASE_SERVICE_ROLE_KEY=""

# Rate limits.
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_PUBLIC_MAX="120"
RATE_LIMIT_ADMIN_MAX="60"

# Active courier runtime for Teknos ID initial production.
LOGISTICS_PROVIDER="jne"

# JNE production credentials. Fill from JNE IT / contract data.
JNE_MODE="production"
JNE_API_BASE_URL="https://apiv2.jne.co.id:10206/tracing/api"
JNE_USERNAME="<jne-username>"
JNE_API_KEY="<jne-api-key>"
JNE_CUST_NO="<jne-customer-number>"
JNE_BRANCH_CODE="<jne-branch-code>"
JNE_ORIGIN_CODE="MJK10000"
JNE_SHIPPER_NAME="<shipper-name>"
JNE_SHIPPER_ADDR1="<shipper-address-line-1>"
JNE_SHIPPER_CITY="<shipper-city>"
JNE_SHIPPER_PHONE="<shipper-phone>"
JNE_SHIPPER_ZIP="<shipper-postal-code>"

# Required only if JNE sends webhook directly to teknos-logistics.
JNE_WEBHOOK_TOKEN=""

# SAP Express is optional. Leave empty unless SAP Express is enabled for production.
SAP_API_BASE_URL=""
SAP_TRACKING_BASE_URL=""
SAP_API_KEY=""
SAP_CUSTOMER_CODE=""
SAP_ORIGIN_DISTRICT_CODE=""
SAP_PICKUP_PLACE="1"
SAP_SHIPMENT_TYPE_CODE="SHTPC"
SAP_SHIPMENT_CONTENT_CODE="SHTPC"
SAP_SHIPPER_NAME=""
SAP_SHIPPER_ADDRESS=""
SAP_SHIPPER_PHONE=""
SAP_SHIPPER_CONTACT=""
SAP_WEBHOOK_TOKEN=""
