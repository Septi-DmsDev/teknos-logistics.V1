generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CourierCode {
  JNE
  JNT
  SAP_EXPRESS
  MOCK
}

enum ShipmentStatus {
  DRAFT
  BOOKED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  FAILED
  CANCELLED
}

enum WebhookRelayStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CourierServiceStatus {
  ACTIVE
  INACTIVE
}

enum AdminOperatorRole {
  SUPER_ADMIN
  OPS_ADMIN
  OPS_VIEWER
  FINANCE
}

model Merchant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys         ApiKey[]
  shipments       Shipment[]
  endpoints       MerchantWebhookEndpoint[]
  stores          Store[]
  origins         Origin[]
  courierServices MerchantCourierService[]
  destinationMappings DestinationMapping[]
  originMappings      OriginMapping[]

  @@index([isActive, createdAt])
}

model Store {
  id         String   @id @default(cuid())
  merchantId String
  slug       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  origins  Origin[]

  @@unique([merchantId, slug])
  @@index([merchantId, isActive])
}

model Origin {
  id         String   @id @default(cuid())
  merchantId String
  storeId    String?
  code       String
  name       String
  address    String?
  city       String?
  province   String?
  postalCode String?
  phone      String?
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant        Merchant                 @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  store           Store?                   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  courierServices MerchantCourierService[]
  originMappings  OriginMapping[]

  @@unique([merchantId, code])
  @@index([merchantId, isActive])
  @@index([storeId, isActive])
}

model CourierService {
  id          String               @id @default(cuid())
  courier     CourierCode
  serviceCode String
  serviceName String
  status      CourierServiceStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  merchants MerchantCourierService[]

  @@unique([courier, serviceCode])
  @@index([courier, status])
}

model MerchantCourierService {
  id               String               @id @default(cuid())
  merchantId       String
  courierServiceId String
  originId         String?
  status           CourierServiceStatus @default(ACTIVE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  merchant       Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  courierService CourierService @relation(fields: [courierServiceId], references: [id], onDelete: Cascade)
  origin         Origin?        @relation(fields: [originId], references: [id], onDelete: Cascade)

  @@unique([merchantId, courierServiceId, originId])
  @@index([merchantId, status])
}

model DestinationMapping {
  id           String      @id @default(cuid())
  merchantId   String
  courier      CourierCode
  country      String      @default("ID")
  province     String?
  city         String?
  district     String?
  subdistrict  String?
  postalCode   String?
  providerCode String
  sourceKey    String?
  label        String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, courier, sourceKey])
  @@index([merchantId, courier, providerCode])
  @@index([merchantId, courier, postalCode, isActive])
  @@index([merchantId, courier, city, isActive])
}

model ProviderOriginCatalog {
  id           String      @id @default(cuid())
  courier      CourierCode
  country      String      @default("ID")
  province     String?
  city         String?
  district     String?
  subdistrict  String?
  postalCode   String?
  providerCode String
  branchCode   String?
  label        String?
  sourceKey    String
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([courier, sourceKey])
  @@index([courier, providerCode])
  @@index([courier, city, isActive])
  @@index([courier, district, isActive])
  @@index([courier, postalCode, isActive])
}

model OriginMapping {
  id           String      @id @default(cuid())
  merchantId   String
  originId     String
  courier      CourierCode
  providerCode String
  label        String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  origin   Origin   @relation(fields: [originId], references: [id], onDelete: Cascade)

  @@unique([originId, courier])
  @@index([merchantId, courier, isActive])
}
model ApiKey {
  id         String    @id @default(cuid())
  merchantId String
  keyHash    String    @unique
  keyPrefix  String
  label      String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, isActive])
  @@index([keyPrefix])
}

model Shipment {
  id               String         @id @default(cuid())
  merchantId       String
  externalOrderId  String
  courier          CourierCode
  courierOrderId   String?
  waybillId        String?
  status           ShipmentStatus @default(DRAFT)
  serviceCode      String
  serviceName      String?
  originCode       String
  destCode         String
  weightGrams      Int
  rateIdr          Int?
  recipientName    String
  recipientPhone   String
  recipientAddress String
  bookedAt         DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  merchant Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  tracking ShipmentTracking[]
  events   WebhookEvent[]

  @@unique([merchantId, externalOrderId])
  @@index([merchantId, status, createdAt])
  @@index([courier, waybillId])
}

model ShipmentTracking {
  id          String         @id @default(cuid())
  shipmentId  String
  status      ShipmentStatus
  description String
  occurredAt  DateTime
  rawPayload  Json?
  createdAt   DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, status, occurredAt, description])
  @@index([shipmentId, occurredAt])
}

model WebhookEvent {
  id          String      @id @default(cuid())
  eventKey    String?     @unique
  shipmentId  String?
  courier     CourierCode
  eventType   String
  rawPayload  Json
  normalized  Json?
  receivedAt  DateTime    @default(now())
  processedAt DateTime?

  shipment      Shipment?             @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  relayAttempts WebhookRelayAttempt[]

  @@index([courier, receivedAt])
  @@index([shipmentId])
}

model MerchantWebhookEndpoint {
  id         String   @id @default(cuid())
  merchantId String
  url        String
  secret     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  attempts WebhookRelayAttempt[]

  @@index([merchantId, isActive])
}

model WebhookRelayAttempt {
  id           String             @id @default(cuid())
  eventId      String
  endpointId   String
  status       WebhookRelayStatus @default(PENDING)
  httpStatus   Int?
  attemptCount Int                @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  event    WebhookEvent            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  endpoint MerchantWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([eventId, endpointId])
  @@index([status, nextRetryAt])
  @@index([eventId])
}

model RateCache {
  id          String      @id @default(cuid())
  courier     CourierCode
  originCode  String
  destCode    String
  weightGrams Int
  rates       Json
  expiresAt   DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([courier, originCode, destCode, weightGrams])
  @@index([expiresAt])
}


model AdminOperator {
  id             String            @id @default(cuid())
  supabaseUserId String            @unique
  email          String
  role           AdminOperatorRole @default(OPS_VIEWER)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([email])
  @@index([role, isActive])
}
model AdminAuditLog {
  id         String   @id @default(cuid())
  method     String
  path       String
  status     Int
  durationMs Int
  requestId  String?
  ipAddress  String?
  userAgent  String?
  operatorId String?
  actorEmail String?
  actorRole  AdminOperatorRole?
  authProvider String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([method, path, createdAt])
  @@index([status, createdAt])
  @@index([operatorId, createdAt])
}
